# Copiar este archivo a `.env` en el mismo directorio y completar los valores.
# Tanto docker-compose (servicio mysql-dw) como el pipeline local (src/main.py)
# leen de este archivo. Mantener ambos sincronizados.

# ---------- Linux host UID (Airflow en Linux) ----------
# En Linux ejecutar `id -u` y pegar el resultado aquí para que los archivos
# escritos por los contenedores de Airflow pertenezcan al usuario del host.
AIRFLOW_UID=1000

# ---------- MySQL Data Warehouse ----------
# El puerto del host es 3307 para evitar colisiones con un MySQL nativo en 3306.
# Dentro de la red Docker, los servicios acceden vía mysql-dw:3306 (puerto interno).
MYSQL_HOST=localhost
MYSQL_PORT=3307
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_USER=etl_user
MYSQL_PASSWORD=etl_password
MYSQL_DW_DB=dw_matriculas_col

# ---------- API Socrata (ICETEX) ----------
# Token opcional — aumenta el rate limit de la API de datos.gov.co
SOCRATA_APP_TOKEN=
