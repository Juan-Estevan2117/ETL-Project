# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
.venv/
env/

# --- Datos (airflow/data/) ---
airflow/data/raw/*
!airflow/data/raw/.gitkeep
!airflow/data/raw/educacionCol_descripcion_columnas_dataset.csv
!airflow/data/raw/descripcion_dataset_api.txt
airflow/data/processed/*
!airflow/data/processed/.gitkeep

# --- Carpeta data/ legacy (ya migrada a airflow/data/) ---
data/

# --- Airflow runtime ---
airflow/logs/*
!airflow/logs/.gitkeep
airflow/.env
airflow/config/airflow.cfg

# --- Jupyter / Notebooks ---
.ipynb_checkpoints
*/.ipynb_checkpoints/*

# --- Logs y Bases de Datos Locales ---
*.log
*.sql.gz

# --- SO ---
.DS_Store
Thumbs.db

# --- Dotfiles internos (Claude, Gemini, etc.) ---
.*
!.gitignore

# --- Markdown (solo README visible) ---
*.md
!README.md
